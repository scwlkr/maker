OPENROUTER_API_KEY=
MODEL_PROVIDER=openrouter
MODEL=nex-agi/nex-n2-pro:free
MODEL_FALLBACKS=poolside/laguna-m.1:free,cohere/north-mini-code:free,openrouter/free,qwen/qwen3-coder:free

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACKS=qwen3.5:9b
OLLAMA_OPTIONS_JSON=

WAKE_INTERVAL_SECONDS=300
CONTEXT_LIMIT_TOKENS=120000
STORE_RAW_OUTPUTS=0

MODEL_TIMEOUT_SECONDS=60
MODEL_TOOL_CHOICE=
TOOL_SCHEMA_MODE=all
TEXT_TOOL_CALL_MODE=disabled
FETCH_TIMEOUT_SECONDS=30
SHELL_TIMEOUT_SECONDS=60
MAX_TOOL_OUTPUT_CHARS=20000
TEXT_ONLY_DELAY_SECONDS=2

WORLD_VOLUME=maker_finn_world
SANDBOX_IMAGE=maker-finn-sandbox:latest
SANDBOX_CPUS=1.0
SANDBOX_MEMORY=512m
SANDBOX_PIDS_LIMIT=256

# For local testing without OpenRouter.
MOCK_MODEL=0
